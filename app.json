{
  "expo": {
    "name": "Gumla Home Delivery Service",
    "slug": "gumla-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gumla",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gumla.homedelivery"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "package": "com.gumla.homedelivery"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ]
  }
}
